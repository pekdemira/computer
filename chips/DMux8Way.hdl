CHIP DMux8Way {
    IN in, sel[3];
    OUT a, b, c, d, e, f, g, h;

    PARTS:
    DMux(in=in, sel=sel[0], a=agce, b=hbfd);
    DMux(in=agce, sel=sel[1], a=ae, b=gc);
    DMux(in=ae, sel=sel[2], a=a, b=e);
    DMux(in=gc, sel=sel[2], a=c, b=g);
    DMux(in=hbfd, sel=sel[1], a=bf, b=dh);
    DMux(in=bf, sel=sel[2], a=b, b=f);
    DMux(in=dh, sel=sel[2], a=d, b=h);
}
